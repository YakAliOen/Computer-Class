<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EADDCA">

    <!-- HEADER LOGO -->
    <ImageView
        android:id="@+id/logoHeader"
        android:layout_width="100dp"
        android:layout_height="60dp"
        android:src="@drawable/Atlas"
        android:scaleType="fitCenter"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <!-- NAVIGATION BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/NBDIV"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E1C16E"
        app:layout_constraintTop_toBottomOf="@id/logoHeader"
        app:layout_constraintBottom_toTopOf="@id/ADDIV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <!-- SEARCH BAR -->
        <EditText
            android:id="@+id/SBAR"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="Search products"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/SBUT" />


        <!-- SEARCH BUTTON -->
        <Button
            android:id="@+id/SBUT"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Search"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/SBAR"
            app:layout_constraintBottom_toBottomOf="@id/SBAR"
            app:layout_constraintStart_toEndOf="@id/SBAR"
            app:layout_constraintEnd_toEndOf="parent" />


        <!-- Navigation Row -->
        <LinearLayout
            android:id="@+id/NBROW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/SBAR"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Deals"
                android:textSize="13dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Categories"
                android:textSize="13dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Orders"
                android:textSize="13dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cart"
                android:textSize="13dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- AD -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ADDIV"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="#CD7F32"
        app:layout_constraintTop_toBottomOf="@id/NBDIV"
        app:layout_constraintBottom_toTopOf="@id/SGDIV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PROMOTIONAL BANNER -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/Promotion"
            android:layout_margin="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- SHOPPING GRID -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/SGDIV"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#DAA06D"
        app:layout_constraintTop_toBottomOf="@id/ADDIV"
        app:layout_constraintBottom_toTopOf="@id/FTDIV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="16dp"
                android:useDefaultMargins="true">

                <!-- PRODUCT 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="#E97451"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@drawable/product1"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Shop for your home essentials"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <!-- PRODUCT 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="#E97451"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@drawable/product2"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Shop Fashion for much less"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </GridLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- FOOTER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/FTDIV"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#D27D2D"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/FTROW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="About Us"
                android:textColor="#FFFFFF"
                android:textAlignment="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Contact"
                android:textColor="#FFFFFF"
                android:textAlignment="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Privacy"
                android:textColor="#FFFFFF"
                android:textAlignment="center"/>

        </LinearLayout>

        <TextView
            android:id="@+id/FTCREDIT"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 Atlas. All Rights Reserved."
            android:textColor="#FFFFFF"
            android:textSize="12dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/FTROW"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
