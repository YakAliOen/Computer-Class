<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EADDCA">

    <!-- HEADER LOGO -->
    <ImageView
        android:id="@+id/logoHeader"
        android:layout_width="100dp"
        android:layout_height="60dp"
        android:src="@drawable/Atlas"
        android:scaleType="fitCenter"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <!-- NAVIGATION BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/NBDIV"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E1C16E"
        app:layout_constraintTop_toBottomOf="@id/logoHeader"
        app:layout_constraintBottom_toTopOf="@id/ADDIV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <!-- SEARCH BAR -->
        <EditText
            android:id="@+id/SBAR"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="Search products"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/SBUT" />


        <!-- SEARCH BUTTON -->
        <Button
            android:id="@+id/SBUT"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Search"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/SBAR"
            app:layout_constraintBottom_toBottomOf="@id/SBAR"
            app:layout_constraintStart_toEndOf="@id/SBAR"
            app:layout_constraintEnd_toEndOf="parent" />


        <!-- Navigation Row -->
        <LinearLayout
            android:id="@+id/NBROW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/SBAR"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Deals"
                android:textSize="13dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Categories"
                android:textSize="13dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Orders"
                android:textSize="13dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cart"
                android:textSize="13dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- PRODUCT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/P"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/NBDIV"
        app:layout_constraintBottom_toTopOf="@id/FTDIV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PRODUCT IMAGE -->
        <ImageView
            android:id="@+id/productImage"
            android:layout_width="160dp"
            android:layout_height="220dp"
            android:src="@drawable/product"
            android:scaleType="fitCenter"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


        <!-- PRODUCT TITLE -->
        <TextView
            android:id="@+id/productTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="ESV Journaling Study Bible (TruTone, Caramel)"
            android:textSize="18dp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="@id/productImage"
            app:layout_constraintStart_toEndOf="@id/productImage"
            app:layout_constraintEnd_toEndOf="parent" />


        <!-- SELLER -->
        <TextView
            android:id="@+id/productAuthor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="by ESV Bibles"
            android:textSize="14dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/productTitle"
            app:layout_constraintStart_toStartOf="@id/productTitle"
            app:layout_constraintEnd_toEndOf="@id/productTitle" />


        <!-- RATING -->
        <TextView
            android:id="@+id/productRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.7/5.0 (1,146 ratings)"
            android:textSize="14dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/productAuthor"
            app:layout_constraintStart_toStartOf="@id/productAuthor" />


        <!-- PRICE -->
        <TextView
            android:id="@+id/productPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$30.06"
            android:textSize="22dp"
            android:textStyle="bold"
            android:textColor="#B12704"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/productRating"
            app:layout_constraintStart_toStartOf="@id/productRating" />


        <TextView
            android:id="@+id/readMore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Read More"
            android:textSize="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/productPrice"
            app:layout_constraintStart_toStartOf="@id/productTitle"
            app:layout_constraintEnd_toEndOf="parent" />


        <!-- ADD TO CART BUTTON -->
        <Button
            android:id="@+id/addToCartButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="Add to Cart"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/productImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- FOOTER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/FTDIV"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#D27D2D"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/FTROW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="About Us"
                android:textColor="#FFFFFF"
                android:textAlignment="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Contact"
                android:textColor="#FFFFFF"
                android:textAlignment="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Privacy"
                android:textColor="#FFFFFF"
                android:textAlignment="center"/>

        </LinearLayout>

        <TextView
            android:id="@+id/FTCREDIT"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 Atlas. All Rights Reserved."
            android:textColor="#FFFFFF"
            android:textSize="12dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/FTROW"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>